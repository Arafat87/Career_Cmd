{
  "name": "careercmd",
  "version": "0.1.0",
  "description": "Career command center — manage job search, resumes, interviews, and career growth.",
  "author": "Arafat Sani",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 3333",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3333 && electron .\"",
    "electron:build": "npm run build && node scripts/prepare-electron.js && electron-builder --win",
    "electron:build:linux": "npm run build && node scripts/prepare-electron.js && electron-builder --linux"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@auth/core": "^0.41.2",
    "@google/generative-ai": "^0.24.1",
    "@react-pdf/renderer": "^4.5.1",
    "better-sqlite3": "^12.10.0",
    "cross-env": "^10.1.0",
    "emoji-picker-react": "^4.19.1",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.38.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "wait-on": "^9.0.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "build": {
    "appId": "com.careercmd.app",
    "productName": "CareerCMD",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "electron-resources/",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": false,
    "npmRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.ico",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
